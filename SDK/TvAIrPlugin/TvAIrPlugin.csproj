<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <TargetFramework>net8.0-windows</TargetFramework>
    <Nullable>enable</Nullable>
    <LangVersion>latest</LangVersion>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>TvAIrPlugin</RootNamespace>
    <AssemblyName>TvAIrPlugin</AssemblyName>
    <Version>$(TvAIrPluginSdkVersion)</Version>
    <FileVersion>$(TvAIrPluginSdkAssemblyVersion)</FileVersion>
    <AssemblyVersion>$(TvAIrPluginSdkAssemblyVersion)</AssemblyVersion>
    <InformationalVersion>$(TvAIrPluginSdkVersion)</InformationalVersion>
    <OutputType>Library</OutputType>
  </PropertyGroup>

</Project>
